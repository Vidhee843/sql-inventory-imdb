            <FormulaField expression="IF Contains([votes], &quot;M&quot;) THEN &#xA;    ToNumber(REGEX_Replace([votes], &quot;[^0-9.]&quot;, &quot;&quot;)) * 1000000&#xA;ELSEIF Contains([votes], &quot;K&quot;) THEN &#xA;    ToNumber(REGEX_Replace([votes], &quot;[^0-9.]&quot;, &quot;&quot;)) * 1000&#xA;ELSE &#xA;    ToNumber(REGEX_Replace([votes], &quot;[^0-9.]&quot;, &quot;&quot;))&#xA;ENDIF" field="votes_clean" size="8" type="Double" />
          </FormulaFields>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <AnnotationText>Formula (votes clean): Remove parenthesis and trim whitespace from votes column and convert K and M suffixes to actual numeric values</AnnotationText>
          <DefaultAnnotationText>votes_clean = IF Contains([votes], "M") THEN 
    ToNumber(REGEX_Replace([votes]...</DefaultAnnotationText>
